{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "blackmeridian-relay",
	"main": "src/index.ts",
	"compatibility_date": "2024-11-01",
	"observability": {
		"enabled": true
	},
	"durable_objects": {
		"bindings": [
			{ "name": "RELAY", "class_name": "Relay" }
		]
	},
	"migrations": [
		{ "tag": "v1", "new_sqlite_classes": ["Relay"] }
	]
}
